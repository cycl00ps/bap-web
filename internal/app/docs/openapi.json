        "responses": {"202": {"description": "Image build job", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ImageBuildJob"}}}}, "403": {"$ref": "#/components/responses/Forbidden"}}
      }
    },
    "/api/base-images/{id}": {
      "patch": {
        "tags": ["Base Images"],
        "operationId": "updateBaseImage",
        "summary": "Update base image status",
        "parameters": [{"$ref": "#/components/parameters/ID"}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/BaseImageStatusRequest"}}}},
        "responses": {"200": {"description": "Updated base image", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/BaseImage"}}}}, "403": {"$ref": "#/components/responses/Forbidden"}}
      },
      "delete": {
        "tags": ["Base Images"],
        "operationId": "deleteBaseImage",
        "summary": "Delete a base image",
        "parameters": [{"$ref": "#/components/parameters/ID"}],
        "responses": {"200": {"description": "Deleted base image", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/DeletedResponse"}}}}, "403": {"$ref": "#/components/responses/Forbidden"}}
      }
    },
    "/api/image-build-jobs/{id}": {
      "get": {
        "tags": ["Base Images"],
        "operationId": "getImageBuildJob",
        "summary": "Get an image build job",
        "parameters": [{"$ref": "#/components/parameters/ID"}],
        "responses": {"200": {"description": "Image build job", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ImageBuildJob"}}}}, "404": {"$ref": "#/components/responses/NotFound"}}
      }
    },
    "/api/image-build-jobs/{id}/logs": {
      "get": {
        "tags": ["Base Images"],
        "operationId": "getImageBuildJobLogs",
        "summary": "Get image build job logs",
        "parameters": [{"$ref": "#/components/parameters/ID"}, {"$ref": "#/components/parameters/Lines"}],
        "responses": {"200": {"description": "Log lines", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/LogLines"}}}}}
      }
    },
    "/api/image-hooks": {
      "get": {
        "tags": ["Image Hooks"],
        "operationId": "listImageHooks",
