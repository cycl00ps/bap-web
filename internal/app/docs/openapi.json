        "responses": {"202": {"description": "Kernel discovery job", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/KernelDiscoveryJob"}}}}, "403": {"$ref": "#/components/responses/Forbidden"}}
      }
    },
    "/api/kernels/firecracker-ci/scan-jobs": {
      "get": {
        "tags": ["Kernels"],
        "operationId": "listKernelDiscoveryJobs",
