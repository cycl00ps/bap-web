{
  "openapi": "3.0.3",
  "info": {
    "title": "BAP Web API",
    "version": "0.1.0",
    "description": "API-first control plane for BAP Firecracker microVMs. Operational API requests require authentication except for the health check."
  },
  "servers": [
    {"url": "/"}
  ],
  "security": [
    {"BearerAuth": []}
  ],
  "tags": [
    {"name": "Health"},
    {"name": "Session"},
    {"name": "Tokens"},
    {"name": "Host"},
    {"name": "SSH Keys"},
    {"name": "Base Images"},
    {"name": "Image Hooks"},
    {"name": "Kernels"},
    {"name": "MicroVMs"},
    {"name": "Networking"}
  ],
  "paths": {
    "/api/health": {
      "get": {
        "tags": ["Health"],
        "operationId": "getHealth",
        "summary": "Check service health",
        "security": [],
        "responses": {
          "200": {"description": "Health status", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Health"}}}}
        }
      }
    },
    "/api/session": {
      "get": {
        "tags": ["Session"],
        "operationId": "getSession",
        "summary": "Inspect the authenticated user or token",
        "responses": {
          "200": {"description": "Current session", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Session"}}}},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/api/tokens": {
      "get": {
        "tags": ["Tokens"],
        "operationId": "listTokens",
        "summary": "List API tokens",
        "responses": {
          "200": {"description": "API tokens", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/APIToken"}}}}},
          "403": {"$ref": "#/components/responses/Forbidden"}
        }
      },
      "post": {
        "tags": ["Tokens"],
        "operationId": "createToken",
        "summary": "Create an API token",
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/APITokenCreateRequest"}}}},
        "responses": {
          "201": {"description": "Created token and one-time secret", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/APITokenCreateResponse"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "403": {"$ref": "#/components/responses/Forbidden"}
        }
      }
    },
    "/api/tokens/{id}": {
      "delete": {
        "tags": ["Tokens"],
        "operationId": "deleteToken",
        "summary": "Revoke an API token",
        "parameters": [{"$ref": "#/components/parameters/ID"}],
        "responses": {
          "200": {"description": "Revoked token", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/RevokedResponse"}}}},
          "403": {"$ref": "#/components/responses/Forbidden"},
          "404": {"$ref": "#/components/responses/NotFound"}
        }
      }
    },
    "/api/users": {
      "get": {
        "tags": ["Users"],
        "operationId": "listUsers",
        "summary": "List users",
        "responses": {
          "200": {"description": "Users", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/UserSummary"}}}}},
          "403": {"$ref": "#/components/responses/Forbidden"}
        }
      }
    },
    "/api/host/status": {
      "get": {
        "tags": ["Host"],
        "operationId": "getHostStatus",
        "summary": "Inspect host integration status",
        "responses": {"200": {"description": "Host status", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HostStatus"}}}}}
      }
    },
    "/api/host/orphans": {
      "get": {
        "tags": ["Host"],
        "operationId": "getHostOrphans",
        "summary": "List orphaned host networking resources",
        "responses": {"200": {"description": "Host orphans", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HostOrphans"}}}}}
      }
    },
    "/api/host/orphans/cleanup": {
      "post": {
        "tags": ["Host"],
        "operationId": "cleanupHostOrphans",
        "summary": "Clean orphaned host networking resources",
        "responses": {"200": {"description": "Cleanup result", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HostOrphans"}}}}}
      }
    },
    "/api/ssh-keys": {
      "get": {
        "tags": ["SSH Keys"],
        "operationId": "listSSHKeys",
        "summary": "List reusable SSH public keys",
        "responses": {"200": {"description": "SSH keys", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/SSHKey"}}}}}}
      }
    },
    "/api/ssh-keys/generate": {
      "post": {
        "tags": ["SSH Keys"],
        "operationId": "generateSSHKey",
        "summary": "Generate a reusable SSH key; private key is returned once",
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SSHKeyRequest"}}}},
        "responses": {"201": {"description": "Generated SSH key", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SSHKeyGenerateResponse"}}}}}
      }
    },
    "/api/ssh-keys/import": {
      "post": {
        "tags": ["SSH Keys"],
        "operationId": "importSSHKey",
        "summary": "Import a reusable SSH public key",
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SSHKeyRequest"}}}},
        "responses": {"201": {"description": "Imported SSH key", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SSHKey"}}}}}
      }
    },
    "/api/ssh-keys/{id}": {
      "get": {
        "tags": ["SSH Keys"],
        "operationId": "getSSHKey",
        "summary": "Get an SSH key",
        "parameters": [{"$ref": "#/components/parameters/ID"}],
        "responses": {"200": {"description": "SSH key", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SSHKey"}}}}, "404": {"$ref": "#/components/responses/NotFound"}}
      },
      "delete": {
        "tags": ["SSH Keys"],
        "operationId": "deleteSSHKey",
        "summary": "Delete an SSH key",
        "parameters": [{"$ref": "#/components/parameters/ID"}],
        "responses": {"200": {"description": "Deleted SSH key", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/DeletedResponse"}}}}, "404": {"$ref": "#/components/responses/NotFound"}}
      }
    },
    "/api/base-images": {
      "get": {
        "tags": ["Base Images"],
        "operationId": "listBaseImages",
        "summary": "List base rootfs images",
        "responses": {"200": {"description": "Base images", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/BaseImage"}}}}}}
      }
    },
    "/api/base-images/register": {
      "post": {
        "tags": ["Base Images"],
        "operationId": "registerBaseImage",
        "summary": "Register an existing base image",
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/RegisterBaseImageRequest"}}}},
        "responses": {"201": {"description": "Registered base image", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/BaseImage"}}}}, "403": {"$ref": "#/components/responses/Forbidden"}}
      }
    },
    "/api/base-images/build": {
      "post": {
        "tags": ["Base Images"],
        "operationId": "buildBaseImage",
