        "responses": {"200": {"description": "Image hooks", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/ImageHook"}}}}}}
      },
      "post": {
        "tags": ["Image Hooks"],
        "operationId": "createImageHook",
        "summary": "Create an image build hook",
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ImageHookRequest"}}}},
        "responses": {"201": {"description": "Image hook", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ImageHook"}}}}}
      }
    },
    "/api/image-hooks/{id}": {
      "delete": {
        "tags": ["Image Hooks"],
        "operationId": "deleteImageHook",
        "summary": "Delete an image build hook",
        "parameters": [{"$ref": "#/components/parameters/ID"}],
        "responses": {"200": {"description": "Deleted image hook", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/DeletedResponse"}}}}}
      }
    },
    "/api/kernels": {
      "get": {
        "tags": ["Kernels"],
        "operationId": "listKernels",
        "summary": "List guest kernels",
