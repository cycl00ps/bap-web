      }
    },
    "/api/kernels/firecracker-ci/scan-jobs/{id}": {
      "get": {
        "tags": ["Kernels"],
        "operationId": "getKernelDiscoveryJob",
        "summary": "Get a kernel discovery job",
        "parameters": [{"$ref": "#/components/parameters/ID"}],
        "responses": {"200": {"description": "Kernel discovery job", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/KernelDiscoveryJob"}}}}, "404": {"$ref": "#/components/responses/NotFound"}}
      }
    },
    "/api/kernels/firecracker-ci/items": {
      "get": {
        "tags": ["Kernels"],
        "operationId": "listKernelDiscoveryItems",
        "summary": "List discovered Firecracker CI kernel items",
        "parameters": [{"name": "job_id", "in": "query", "required": false, "schema": {"type": "string"}}],
        "responses": {"200": {"description": "Kernel discovery items", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/KernelDiscoveryItem"}}}}}}
      }
    },
    "/api/kernels/import-firecracker-ci": {
      "post": {
        "tags": ["Kernels"],
        "operationId": "importFirecrackerCIKernel",
        "summary": "Import a discovered or typed Firecracker CI kernel",
