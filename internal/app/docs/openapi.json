        "responses": {"201": {"description": "Imported kernel", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Kernel"}}}}, "403": {"$ref": "#/components/responses/Forbidden"}}
      }
    },
    "/api/kernels/upload": {
      "post": {
        "tags": ["Kernels"],
        "operationId": "uploadKernel",
        "summary": "Upload a guest kernel",
        "requestBody": {"required": true, "content": {"multipart/form-data": {"schema": {"$ref": "#/components/schemas/KernelUploadRequest"}}}},
